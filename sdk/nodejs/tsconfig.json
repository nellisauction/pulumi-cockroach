{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "allowList.ts",
        "apiKey.ts",
        "blackoutWindow.ts",
        "clientCaCert.ts",
        "cluster.ts",
        "cmek.ts",
        "config/index.ts",
        "config/vars.ts",
        "database.ts",
        "egressPrivateEndpoint.ts",
        "egressPrivateEndpointDomainNames.ts",
        "egressRule.ts",
        "egressTrafficPolicy.ts",
        "finalizeVersionUpgrade.ts",
        "folder.ts",
        "getBackups.ts",
        "getBlackoutWindows.ts",
        "getCluster.ts",
        "getClusterCert.ts",
        "getConnectionString.ts",
        "getFolder.ts",
        "getOrganization.ts",
        "getPersonUser.ts",
        "getRestores.ts",
        "index.ts",
        "jwtIssuer.ts",
        "logExportConfig.ts",
        "maintenanceWindow.ts",
        "metricExportCloudwatchConfig.ts",
        "metricExportDatadogConfig.ts",
        "metricExportPrometheusConfig.ts",
        "physicalReplicationStream.ts",
        "privateEndpointConnection.ts",
        "privateEndpointServices.ts",
        "privateEndpointTrustedOwner.ts",
        "provider.ts",
        "restore.ts",
        "serviceAccount.ts",
        "sqlUser.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "userRoleGrant.ts",
        "userRoleGrants.ts",
        "utilities.ts",
        "versionDeferral.ts"
    ]
}
